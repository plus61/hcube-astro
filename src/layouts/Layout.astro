<script>
// Elementor popup menu (hamburger) — popup ID 357
// ハンバーガーアイコンは href="#elementor-action:action=popup:open&settings=eyJpZCI6IjM1NyIsInRvZ2dsZSI6ZmFsc2V9"
// Elementorのポップアップ機能なのでvanilla JSで代替
const popupOverlay = document.querySelector('#elementor-popup-modal-357 .dialog-lightbox-overlay');
const popupClose = document.querySelector('#elementor-popup-modal-357 .dialog-lightbox-close-button');

// スムーズスクロール
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
  anchor.addEventListener('click', function(e) {
    const href = this.getAttribute('href');
    if (href === '#' || href.startsWith('#elementor-action')) return;
    const target = document.querySelector(href);
    if (target) {
      e.preventDefault();
      target.scrollIntoView({ behavior: 'smooth' });
    }
  });
});

// ページ読み込み時のハッシュスクロール（固定ヘッダー対応）
if (window.location.hash && !window.location.hash.startsWith('#elementor-action')) {
  requestAnimationFrame(() => {
    const el = document.querySelector(window.location.hash);
    if (el) el.scrollIntoView({ behavior: 'smooth' });
  });
}
</script>

